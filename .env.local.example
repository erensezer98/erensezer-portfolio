# Supabase — copy from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used for server-side operations (optional — only needed for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional - used to load public images directly from your Google Drive project folders
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key

# Optional - used to load public images for non-project pages too
# about: portrait, gallery | awards: cover
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key
